# Optional backend-only settings.
# You only need this file if you want to run the self-hosted backend mode.

# Local backend port for the Node server in this repo.
PORT=3000

# Required for backend mode: choose one provider.
# Supported values: gemini, xai, openai-compatible
AI_PROVIDER=gemini

# Required for backend mode: your provider API key.
AI_API_KEY=your_api_key_here

# Optional for backend mode:
# - Gemini falls back to gemini-2.5-flash if AI_MODEL is blank.
# - xAI and other OpenAI-compatible providers usually need an explicit model.
AI_MODEL=

# Optional for xAI and openai-compatible backends.
# Example: https://api.openai.com/v1
# Example: https://api.x.ai/v1
AI_BASE_URL=

# Optional compatibility aliases:
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=your_openai_compatible_api_key_here
# OPENAI_MODEL=your_openai_compatible_model_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# XAI_API_KEY=your_xai_api_key_here
# XAI_MODEL=grok-4.20-reasoning
# XAI_BASE_URL=https://api.x.ai/v1

# Optional: comma-separated allowlist of extension origins.
# Leave blank for quick local use, or set it before sharing/deploying the backend.
# Example: chrome-extension://YOUR_EXTENSION_ID
# Example with multiple origins: chrome-extension://DEV_ID,chrome-extension://PROD_ID
ALLOWED_EXTENSION_ORIGINS=

# Optional: enable extra backend logging for prompt/token metrics.
# Use true to enable, false or blank to disable.
CLARITY_LOG_PROMPT_METRICS=false

# Optional: override the backend request timeout in milliseconds.
# Example: 120000
# CLARITY_REQUEST_TIMEOUT_MS=
